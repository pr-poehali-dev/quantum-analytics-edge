{
  "tests": [
    {
      "name": "Список битов — OK",
      "method": "GET",
      "path": "/?action=list-beats",
      "expectedStatus": 200
    },
    {
      "name": "Список новинок лейбла",
      "method": "GET",
      "path": "/?action=list-label-releases",
      "expectedStatus": 200
    },
    {
      "name": "Список артистов лейбла",
      "method": "GET",
      "path": "/?action=list-artists",
      "expectedStatus": 200
    },
    {
      "name": "Удалить бит без токена — 403",
      "method": "POST",
      "path": "/?action=del-beat",
      "body": {"id": 999},
      "expectedStatus": 403,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Список интервью",
      "method": "GET",
      "path": "/?action=list-interviews",
      "expectedStatus": 200
    },
    {
      "name": "Добавить интервью без токена — 403",
      "method": "POST",
      "path": "/?action=add-interview",
      "body": {"artist_name": "Test", "question": "Q", "answer": "A"},
      "expectedStatus": 403,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}