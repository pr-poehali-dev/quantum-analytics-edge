{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Artists without token — 403",
      "method": "GET",
      "path": "/?action=artists",
      "expectedStatus": 403,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Statistics without token — 401",
      "method": "GET",
      "path": "/?action=statistics",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Radio tracks — public GET",
      "method": "GET",
      "path": "/?action=radio-tracks",
      "expectedStatus": 200,
      "expectedBody": {"tracks": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Create release without token — 401",
      "method": "POST",
      "path": "/?action=releases",
      "body": {"title": "Test Release"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Upload audio without token — 401",
      "method": "POST",
      "path": "/?action=upload-audio",
      "body": {},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
