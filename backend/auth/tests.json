{
  "tests": [
    {
      "name": "OPTIONS preflight check",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Login empty fields",
      "method": "POST",
      "path": "/?action=login",
      "body": {},
      "expectedStatus": 400,
      "expectedBody": {"error": "Заполните все поля"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong password",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "noone@test.com", "password": "wrongpass"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Неверный email или пароль"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Me without token",
      "method": "GET",
      "path": "/?action=me",
      "expectedStatus": 401,
      "expectedBody": {"error": "Не авторизован"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Forgot password empty email",
      "method": "POST",
      "path": "/?action=forgot-password",
      "body": {},
      "expectedStatus": 400,
      "expectedBody": {"error": "Введите email"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Forgot password unknown email — returns ok",
      "method": "POST",
      "path": "/?action=forgot-password",
      "body": {"email": "notexist@test.com"},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    }
  ]
}